{
  "name": "arc-raiders-cheats",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/optimize-images.mjs && node scripts/copy-fonts.mjs && node scripts/generate-sitemap.mjs && astro build && node scripts/verify-seo.mjs",
    "preview": "npm run build && wrangler dev --assets=dist",
    "optimize:images": "node scripts/optimize-images.mjs",
    "generate:blog-images": "node scripts/generate-blog-images.mjs",
    "generate:brand": "node scripts/generate-brand-assets.mjs",
    "postinstall": "node scripts/copy-fonts.mjs",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "astro": "^7.0.3",
    "framer-motion": "^12.42.0",
    "lucide": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "swiper": "^14.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "rehype-slug": "^6.0.0",
    "sharp": "^0.35.2",
    "wrangler": "^4.106.0"
  }
}
