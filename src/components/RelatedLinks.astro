---
interface RelatedLink {
  href: string;
  label: string;
  description?: string;
}

interface Props {
  title?: string;
  links: RelatedLink[];
}

const { title = 'Related pages', links } = Astro.props;
---

<aside class="related-links" aria-label={title}>
  <h2 class="related-links-title">{title}</h2>
  <ul class="related-links-list">
    {links.map((link) => (
      <li>
        <a href={link.href}>
          <span class="related-links-label">{link.label}</span>
          {link.description && <span class="related-links-desc">{link.description}</span>}
        </a>
      </li>
    ))}
  </ul>
</aside>

<style>
  .related-links {
    margin-top: 2rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius2);
    background: var(--bg2);
  }

  .related-links-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.85rem;
  }

  .related-links-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.65rem;
  }

  .related-links-list a {
    display: block;
    padding: 0.65rem 0.75rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg3);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }

  .related-links-list a:hover {
    border-color: rgba(124, 58, 237, 0.45);
  }

  .related-links-label {
    display: block;
    font-weight: 600;
    font-size: 0.92rem;
  }

  .related-links-desc {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.78rem;
    color: var(--text2);
    line-height: 1.45;
  }
</style>
