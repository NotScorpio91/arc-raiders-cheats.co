---

import type { IconName } from '../lib/icons';

import Icon from './Icon.astro';



interface Props {

  icon?: IconName;

  label: string;

  class?: string;

}



const { icon = 'tag', label, class: className = '' } = Astro.props;

---



<span class:list={['icon-label', className]}>

  <Icon name={icon} size={12} />

  {label}

</span>


