---
import type { IconName } from '../lib/icons';
import Icon from './Icon.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  href: string;
  icon?: IconName;
  readTime?: string;
}

const { title, description, date, href, icon = 'file-text', readTime } = Astro.props;
---

<a href={href} class="blog-card">
  <div class="blog-card-accent" aria-hidden="true"></div>
  <div class="blog-card-head">
    <div class="blog-card-icon">
      <Icon name={icon} size={22} />
    </div>
    <div class="blog-card-title-wrap">
      <span class="blog-card-date">
        <Icon name="calendar" size={12} />
        {date}
      </span>
      <h3 class="blog-card-name">{title}</h3>
    </div>
  </div>

  <p class="blog-card-desc">{description}</p>

  <div class="blog-card-meta">
    {readTime && (
      <span class="blog-card-pill">
        <Icon name="clock" size={11} />
        {readTime}
      </span>
    )}
    <span class="blog-card-pill">
      <Icon name="newspaper" size={11} />
      Article
    </span>
  </div>

  <span class="blog-card-btn">
    Read Article
    <Icon name="chevron-right" size={14} />
  </span>
</a>
