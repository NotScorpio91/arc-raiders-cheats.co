---
import type { MediaItem } from '../lib/media';

interface Props {
  media: MediaItem[];
}

const { media } = Astro.props;
const images = media.filter((item) => item.type === 'image');
const slideCount = images.length;
const duration = slideCount * 4;
const step = 100 / slideCount;
const hold = step * 0.88;

const keyframeSteps: string[] = [];
for (let i = 0; i < slideCount; i++) {
  const start = (i * step).toFixed(2);
  const end = Math.min((i * step + hold).toFixed(2), (100 - step * 0.05).toFixed(2));
  const offset = slideCount > 1 ? `calc(-100% * ${i} / ${slideCount})` : '0';
  keyframeSteps.push(`${start}%, ${end}% { transform: translateX(${offset}); }`);
}
if (slideCount > 1) {
  keyframeSteps.push(`100% { transform: translateX(calc(-100% * ${slideCount - 1} / ${slideCount})); }`);
}
const keyframesCss = `@keyframes showcase-autoplay { ${keyframeSteps.join(' ')} }`;
---

<div
  class="showcase-scroll-wrap"
  style={`--slide-count: ${slideCount}; --duration: ${duration}s`}
>
  <div class="showcase-track" aria-label="Cheat screenshot gallery">
    {images.map((item) => (
      <figure class="showcase-slide">
        {item.label && <span class="cheat-slide-label">{item.label}</span>}
        <img
          src={item.src}
          srcset={`${item.src.replace('.webp', '-640.webp')} 640w, ${item.src} 960w`}
          alt={item.alt}
          class="cheat-slide-media"
          width={960}
          height={540}
          loading="lazy"
          decoding="async"
          sizes="(max-width: 900px) 100vw, 960px"
        />
      </figure>
    ))}
  </div>
</div>

<style is:global set:html={keyframesCss}></style>

<style>
  .showcase-scroll-wrap {
    background: var(--bg2);
    border: 1px solid var(--border);
    overflow: hidden;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%);
  }

  .showcase-track {
    display: flex;
    width: calc(var(--slide-count) * 100%);
    animation: showcase-autoplay var(--duration) ease-in-out infinite;
  }

  .showcase-scroll-wrap:hover .showcase-track {
    animation-play-state: paused;
  }

  .showcase-slide {
    position: relative;
    flex: 0 0 calc(100% / var(--slide-count));
    aspect-ratio: 16 / 9;
    margin: 0;
  }

  .showcase-slide .cheat-slide-media {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-track {
      animation: none;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      width: 100%;
    }

    .showcase-track::-webkit-scrollbar {
      display: none;
    }

    .showcase-slide {
      flex: 0 0 100%;
      scroll-snap-align: start;
    }
  }
</style>
