---
import type { BlogCardData } from '../lib/blog';
import { BLOG_CATEGORY_ICONS } from '../lib/blog';
import type { BlogCategory } from '../lib/blog';
import Icon from './Icon.astro';
import MotionBlogCard from './react/MotionBlogCard';

interface Props {
  posts: BlogCardData[];
  title?: string;
}

const { posts, title = 'Related guides' } = Astro.props;
---

{posts.length > 0 && (
  <aside class="related-posts" aria-label="Related blog posts">
    <div class="s-tag">// Related</div>
    <h2 class="related-posts-title">{title}</h2>
    <div class="related-posts-grid">
      {posts.map((post, i) => {
        const catIcon = post.category
          ? BLOG_CATEGORY_ICONS[post.category as BlogCategory]
          : 'newspaper';
        return (
          <MotionBlogCard client:visible delay={i * 0.06}>
            <a href={post.href} class="related-post-card">
              {post.coverImage && (
                <div class="related-post-cover">
                  <img
                    src={post.coverImage}
                    alt={post.coverImageAlt ?? post.title}
                    loading="lazy"
                    width="400"
                    height="225"
                    decoding="async"
                  />
                </div>
              )}
              <div class="related-post-body">
                <Icon name={catIcon} size={16} />
                <h3>{post.title}</h3>
                {post.readTime && <span>{post.readTime}</span>}
              </div>
            </a>
          </MotionBlogCard>
        );
      })}
    </div>
  </aside>
)}

<style>
  .related-posts {
    margin-top: 2rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    background: var(--bg2);
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%);
  }

  .related-posts-title {
    font-size: 1.1rem;
    font-weight: 800;
    margin: 0.35rem 0 1rem;
  }

  .related-posts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .related-post-card {
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    border: 1px solid var(--border);
    background: var(--bg3);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }

  .related-post-card:hover {
    border-color: color-mix(in srgb, var(--accent2) 45%, var(--border));
  }

  .related-post-cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .related-post-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .related-post-body {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .related-post-body h3 {
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
  }

  .related-post-body span {
    font-size: 0.68rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  @media (max-width: 768px) {
    .related-posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
