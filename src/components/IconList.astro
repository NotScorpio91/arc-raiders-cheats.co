---
import Icon from './Icon.astro';

interface Props {
  items: string[];
  icon?: 'check' | 'chevron-right';
}

const { items, icon = 'check' } = Astro.props;
---

<ul class="icon-list">
  {items.map((item) => (
    <li>
      <Icon name={icon} size={14} class="icon-list-mark" />
      <span>{item}</span>
    </li>
  ))}
</ul>

<style>
  .icon-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .icon-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .icon-list-mark {
    flex-shrink: 0;
    margin-top: 0.2rem;
    color: var(--accent2);
  }
</style>
