---
import type { IconName } from '../lib/icons';
import Icon from './Icon.astro';

interface Props {
  id: string;
  icon: IconName;
  name: string;
  description: string;
  features: string[];
  tier?: string;
  featured?: boolean;
}

const { id, icon, name, description, features, tier, featured = false } = Astro.props;

const previewFeatures = features.slice(0, 5);
const hiddenCount = Math.max(0, features.length - previewFeatures.length);
---

<article class="cheat-card">
  <div class="cheat-card-accent" aria-hidden="true"></div>
  <div class="cheat-card-head">
    <div class="cheat-card-icon">
      <Icon name={icon} size={22} />
    </div>
    <div class="cheat-card-title-wrap">
      {tier && <span class="cheat-card-tier">{tier}</span>}
      <h3 class="cheat-card-name">{name}</h3>
    </div>
    {featured && <span class="cheat-card-badge">Popular</span>}
  </div>

  <p class="cheat-card-desc">{description}</p>

  <div class="cheat-card-meta">
    <span class="cheat-card-count">{features.length} Features</span>
  </div>

  <ul class="cheat-card-features">
    {previewFeatures.map((feature) => (
      <li>{feature}</li>
    ))}
  </ul>

  {hiddenCount > 0 && <p class="cheat-card-more">+ {hiddenCount} more features</p>}

  <a href={`/products/${id}/`} class="cheat-card-btn">
    Show More
    <Icon name="chevron-right" size={14} />
  </a>
</article>
