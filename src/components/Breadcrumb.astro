---
interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;
---

<nav class="breadcrumb" aria-label="Breadcrumb">
  {items.map((item, i) => (
    <>
      {item.href ? (
        <a href={item.href}>{item.label}</a>
      ) : (
        <span>{item.label}</span>
      )}
      {i < items.length - 1 && <span>/</span>}
    </>
  ))}
</nav>
