---
import { SITE } from '../lib/site';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<a href="/" class:list={['logo-brand', className]}>
  <img src="/logo.webp" alt={SITE.logoAlt} class="logo-mark" width="40" height="47" loading="lazy" decoding="async" />
  <span class="logo-text">ZAD<span>EYO</span></span>
</a>

<style>
  .logo-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: inherit;
  }

  .logo-mark {
    flex-shrink: 0;
    display: block;
    height: 34px;
    width: auto;
    max-width: 44px;
    object-fit: contain;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .logo-text {
    font-size: 1.15rem;
    font-weight: 900;
    letter-spacing: 2px;
    text-transform: uppercase;
    line-height: 1;
  }

  .logo-text span {
    color: var(--accent2);
  }

  .logo-brand:hover .logo-mark {
    transform: rotate(-6deg) scale(1.06);
  }
</style>
