---
import { localeHref } from '../lib/i18n';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
const locale = Astro.currentLocale ?? 'en';
const homeHref = localeHref(locale, '/');
---

<a href={homeHref} class:list={['logo-brand', className]} aria-label="Arc Raiders Cheats">
  <img
    src="/logo.svg"
    alt="Arc Raiders Cheats logo mark"
    class="logo-mark"
    width="34"
    height="34"
    decoding="async"
  />
  <span class="logo-text">Arc <span>Raiders</span> Cheats</span>
</a>

<style>
  .logo-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, filter 0.25s ease;
  }

  .logo-brand:hover {
    transform: translateY(-1px);
  }

  .logo-brand:hover .logo-mark {
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--accent2) 45%, transparent));
  }

  .logo-mark {
    flex-shrink: 0;
    display: block;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    transition: filter 0.25s ease, transform 0.25s ease;
  }

  .logo-brand:active .logo-mark {
    transform: scale(0.96);
  }

  .logo-text {
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1.1;
    white-space: nowrap;
  }

  .logo-text span {
    color: var(--accent2);
  }

  @media (max-width: 720px) {
    .logo-text {
      font-size: 0.95rem;
    }
  }
</style>
