---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<a href="/" class:list={['logo-brand', className]} aria-label="Arc Raiders Cheats">
  <img
    src="/favicon.svg"
    alt="Arc Raiders Cheats logo mark"
    class="logo-mark"
    width="34"
    height="34"
    decoding="async"
  />
  <span class="logo-text">Arc <span>Raiders</span> Cheats</span>
</a>

<style>
  .logo-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: inherit;
  }

  .logo-mark {
    flex-shrink: 0;
    display: block;
    width: 34px;
    height: 34px;
    border-radius: 8px;
  }

  .logo-text {
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1.1;
    white-space: nowrap;
  }

  .logo-text span {
    color: var(--accent2);
  }

  @media (max-width: 720px) {
    .logo-text {
      font-size: 0.95rem;
    }
  }
</style>
