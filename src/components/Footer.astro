---
import { SITE } from '../lib/site';
import { getMessages, localeHref } from '../lib/i18n';
import Logo from './Logo.astro';
import Icon from './Icon.astro';

const locale = Astro.currentLocale ?? 'en';
const t = getMessages(locale);
---

<footer>
  <div class="footer-inner">
    <div class="f-grid">
      <div class="f-brand">
        <Logo />
        <p>{t.footer.tagline}</p>
      </div>
      <div class="f-col">
        <h3>{t.footer.content}</h3>
        <ul>
          <li><a href={localeHref(locale, '/cheats/')}><Icon name="crosshair" size={14} /> {t.footer.cheats}</a></li>
          <li><a href={localeHref(locale, '/products/')}><Icon name="cloud" size={14} /> {t.footer.products}</a></li>
          <li><a href={localeHref(locale, '/blog/')}><Icon name="newspaper" size={14} /> {t.footer.blog}</a></li>
        </ul>
      </div>
      <div class="f-col">
        <h3>{t.footer.site}</h3>
        <ul>
          <li><a href={localeHref(locale, '/about/')}><Icon name="guide" size={14} /> {t.footer.about}</a></li>
          <li><a href={localeHref(locale, '/contact/')}><Icon name="mail" size={14} /> {t.footer.contact}</a></li>
          <li><a href={localeHref(locale, '/faq/')}><Icon name="file-text" size={14} /> {t.footer.faq}</a></li>
        </ul>
      </div>
      <div class="f-col">
        <h3>{t.footer.legal}</h3>
        <ul>
          <li><a href={localeHref(locale, '/privacy-policy/')}><Icon name="shield" size={14} /> {t.footer.privacy}</a></li>
          <li><a href={localeHref(locale, '/terms/')}><Icon name="file-text" size={14} /> {t.footer.terms}</a></li>
        </ul>
      </div>
    </div>
    <div class="f-bottom">
      <p>© {new Date().getFullYear()} {SITE.name}. {t.footer.copyright}</p>
      <p class="f-disclaimer">{t.footer.disclaimer}</p>
    </div>
  </div>
</footer>
