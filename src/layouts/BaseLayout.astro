---
import '../styles/global.css';
import { SITE, SITE_LOGO_URL, PRECONNECT_ORIGINS } from '../lib/site';
import { buildTitle, buildCanonical, trimDescription } from '../lib/seo';
import { organizationSchema, webPageSchema } from '../lib/schema';
import { resolveSocialImage, resolveOgImageUrl } from '../lib/social-images';
import SchemaOrg from '../components/SchemaOrg.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  keywords?: string[];
  articlePublished?: string;
  articleModified?: string;
  lcpImage?: string;
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage,
  ogImageAlt,
  noindex = false,
  schema,
  keywords = [],
  articlePublished,
  articleModified,
  lcpImage,
} = Astro.props;

const pageTitle = buildTitle(title);
const metaDescription = trimDescription(description);
const canonicalUrl = canonical ?? buildCanonical(Astro.url.pathname);
const socialImage = resolveSocialImage(Astro.url.pathname);
const ogImageSrc = ogImage ?? socialImage.src;
const ogImageAltText = ogImageAlt ?? socialImage.alt;
const ogImageUrl = resolveOgImageUrl(ogImageSrc, SITE.url);
const jsonLd = [
  organizationSchema(),
  webPageSchema({
    name: pageTitle,
    description: metaDescription,
    url: canonicalUrl,
    image: ogImageUrl,
    imageAlt: ogImageAltText,
    imageWidth: socialImage.width,
    imageHeight: socialImage.height,
  }),
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : []),
];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var theme =
            stored ||
            (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="author" content={SITE.author} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
    <meta name="theme-color" content={SITE.themeColor} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="icon" type="image/png" href={SITE.logo} sizes="32x32" />
    <link rel="icon" type="image/png" href={SITE.logo} sizes="192x192" />
    <link rel="apple-touch-icon" href={SITE.logo} />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    {PRECONNECT_ORIGINS.map((origin) => (
      <>
        <link rel="preconnect" href={origin} crossorigin />
        <link rel="dns-prefetch" href={origin} />
      </>
    ))}
    {lcpImage && (
      <link rel="preload" as="image" href={lcpImage} fetchpriority="high" />
    )}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:width" content={String(socialImage.width)} />
    <meta property="og:image:height" content={String(socialImage.height)} />
    <meta property="og:image:alt" content={ogImageAltText} />
    <meta property="og:logo" content={SITE_LOGO_URL} />
    <meta property="og:locale" content={SITE.locale} />
    <meta itemprop="name" content={pageTitle} />
    <meta itemprop="description" content={metaDescription} />
    <meta itemprop="logo" content={SITE_LOGO_URL} />
    <meta itemprop="image" content={ogImageUrl} />
    {articlePublished && <meta property="article:published_time" content={articlePublished} />}
    {articleModified && <meta property="article:modified_time" content={articleModified} />}
    {keywords.map((keyword) => (
      <meta property="article:tag" content={keyword} />
    ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.twitter} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAltText} />

    <meta name="generator" content={Astro.generator} />
    <SchemaOrg schema={jsonLd} />
    <ClientRouter />
    <script is:inline>
      (function () {
        if (window.__arcNavInit) return;
        window.__arcNavInit = true;

        var hideTimer = null;
        var fadeTimer = null;
        var showTime = 0;
        var hiding = false;
        var MIN_VISIBLE_MS = 380;
        var FADE_OUT_MS = 220;

        function getLoader() {
          return document.getElementById('page-loader');
        }

        function isInternalNavLink(link) {
          if (!link || link.origin !== location.origin) return false;
          if (link.hasAttribute('download') || link.target === '_blank') return false;
          var path = link.getAttribute('href');
          if (!path || path.startsWith('#') || path.startsWith('mailto:')) return false;
          var targetPath = path.split('?')[0].split('#')[0];
          return targetPath !== location.pathname;
        }

        function showLoader() {
          var loader = getLoader();
          if (!loader) return;

          hiding = false;
          clearTimeout(hideTimer);
          clearTimeout(fadeTimer);

          showTime = Date.now();
          document.documentElement.classList.add('is-navigating');
          loader.classList.remove('is-leaving');
          loader.classList.add('is-active');
          loader.setAttribute('aria-hidden', 'false');
          void loader.offsetHeight;
        }

        function hideLoader() {
          var loader = getLoader();
          if (!loader || !loader.classList.contains('is-active') || hiding) return;

          var elapsed = Date.now() - showTime;
          var waitBeforeFade = Math.max(60, MIN_VISIBLE_MS - elapsed);

          clearTimeout(hideTimer);
          hideTimer = setTimeout(function () {
            hiding = true;
            loader.classList.add('is-leaving');

            clearTimeout(fadeTimer);
            fadeTimer = setTimeout(function () {
              loader.classList.remove('is-active', 'is-leaving');
              loader.setAttribute('aria-hidden', 'true');
              document.documentElement.classList.remove('is-navigating');
              hiding = false;
            }, FADE_OUT_MS);
          }, waitBeforeFade);
        }

        document.addEventListener('astro:before-preparation', showLoader);
        document.addEventListener('astro:page-load', hideLoader);

        document.addEventListener('click', function (e) {
          var link = e.target.closest('a[href]');
          if (!isInternalNavLink(link)) return;
          showLoader();
        }, true);

        document.addEventListener('click', function (e) {
          var toggle = e.target.closest('.nav-toggle');
          if (!toggle) return;
          var menu = document.querySelector('.nav-links');
          var open = menu?.classList.toggle('open');
          toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <div id="page-loader" class="page-loader-static" aria-hidden="true" transition:persist="page-loader">
      <div class="page-loader-simple" role="status" aria-label="Loading page">
        <div class="page-loader-spinner" aria-hidden="true"></div>
        <img src={SITE.logo} alt={SITE.logoAlt} width="40" height="47" class="page-loader-logo" />
      </div>
    </div>

    <Nav transition:persist />
    <main id="main-content">
      <slot />
    </main>
    <Footer transition:persist />
  </body>
</html>
