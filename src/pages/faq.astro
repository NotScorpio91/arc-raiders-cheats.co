---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import IconLabel from '../components/IconLabel.astro';
import MotionFAQ from '../components/react/MotionFAQ';
import MotionReveal from '../components/react/MotionReveal';
import { faqSchema, breadcrumbSchema } from '../lib/schema';
import { SITE, GET_ACCESS_URL, CONTACT_URL } from '../lib/site';
import { resolveSocialImage } from '../lib/social-images';

const faqSocial = resolveSocialImage('/faq/');

const generalFaqs = [
  {
    question: 'How often is content updated?',
    answer:
      'We review cheat tiers, product pages, and blog posts within 48 hours of major Arc Raiders patches. Weapon balance, loot tables, and extraction routes are checked first.',
  },
  {
    question: 'Which cheat tier should I start with?',
    answer:
      'Start with Xray if you mainly need ESP and loot visibility. Choose Pro for combat automation, or Private for the full radar and extraction intel stack.',
  },
  {
    question: 'Does Cloud DMA include AWS or GREENWARD?',
    answer:
      'No. Cloud DMA on our site covers the Hyper-V infrastructure layer only. AWS and GREENWARD are separate purchases required for the supported workflow.',
  },
  {
    question: 'Can I suggest a guide topic?',
    answer:
      'Yes. Use the Contact button to reach support. We prioritize topics that multiple players request.',
  },
  {
    question: 'Do you accept guest contributions?',
    answer:
      'We consider guest guides from experienced players with verifiable in-game experience. Use Contact if you want to discuss a writing sample or your area of expertise.',
  },
  {
    question: 'What payment methods are available?',
    answer:
      'Checkout supports cards, Apple Pay, and Google Pay with instant delivery. Regional payment options are listed on the checkout page when available.',
  },
  {
    question: 'How do I get access after purchase?',
    answer:
      'Click Get Access on any cheat or product page — you are taken straight to checkout for instant delivery. Setup steps and activation details follow immediately after purchase.',
  },
];

const schema = [
  faqSchema(generalFaqs, faqSocial.src),
  breadcrumbSchema([
    { name: 'Home', url: `${SITE.url}/` },
    { name: 'FAQ', url: `${SITE.url}/faq/` },
  ]),
];
---

<BaseLayout
  title="Arc Raiders Cheats FAQ 2026"
  description="Arc Raiders cheats FAQ — Xray, Pro, and Private tiers, Cloud DMA prerequisites, HWID spoofer basics, and setup questions answered."
  canonical={`${SITE.url}/faq/`}
  schema={schema}
  keywords={['arc raiders cheats faq', 'arc raiders esp help', 'cloud dma faq', 'hwid spoofer faq']}
>
  <section class="section listing-section">
    <div class="section-inner">
      <Breadcrumb
        items={[
          { name: 'Home', href: '/' },
          { name: 'FAQ' },
        ]}
      />
      <MotionReveal client:visible>
        <div class="listing-intro">
          <IconLabel icon="info" label="FAQ" />
          <h1>Arc Raiders Cheats FAQ</h1>
          <p class="listing-intro-desc">
            Answers about cheat tiers, products, Cloud DMA prerequisites, and support —
            beyond the quick FAQ on our homepage.
          </p>
        </div>
        <MotionFAQ client:visible items={generalFaqs} />
        <div class="cta-banner" style="margin-top: 2rem;">
          <h2>Need Help?</h2>
          <p>Contact support for Arc Raiders cheats, products, and setup questions — or get access when you are ready.</p>
          <div class="hero-btns" style="justify-content: center; margin-top: 1rem;">
            <button type="button" class="btn-primary" data-go-url={CONTACT_URL}>Contact</button>
            <button type="button" class="btn-ghost" data-go-url={GET_ACCESS_URL}>Get Access</button>
          </div>
        </div>
      </MotionReveal>
    </div>
  </section>
</BaseLayout>
