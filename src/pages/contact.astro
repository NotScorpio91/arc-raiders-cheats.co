---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contactPageSchema, breadcrumbSchema } from '../lib/schema';
import { SITE, CONTACT_URL } from '../lib/site';
import { resolveSocialImage } from '../lib/social-images';

const contactSocial = resolveSocialImage('/contact/');

const schema = [
  contactPageSchema(contactSocial.src),
  breadcrumbSchema([
    { name: 'Home', url: SITE.url },
    { name: 'Contact', url: `${SITE.url}/contact/` },
  ]),
];
---

<BaseLayout
  title="Contact Arc Raiders Cheats — Support"
  description="Contact ArcRaidersCheats for support on Arc Raiders cheats, Cloud DMA, UGC, and HWID Spoofer. Get help with setup, access, and product questions."
  canonical={`${SITE.url}/contact/`}
  schema={schema}
>
  <section class="section listing-section">
    <div class="section-inner">
      <div class="listing-intro">
        <div class="s-tag">// Contact</div>
        <h1>Contact</h1>
        <p class="listing-intro-desc">
          Need help with Arc Raiders cheats, Cloud DMA, UGC, or HWID Spoofer? Reach support through
          the button below for setup help, access questions, and product guidance.
        </p>
      </div>

      <div class="form-page form-page--inline">
        <button type="button" class="btn-primary" data-go-url={CONTACT_URL}>Contact</button>
      </div>
    </div>
  </section>
</BaseLayout>
