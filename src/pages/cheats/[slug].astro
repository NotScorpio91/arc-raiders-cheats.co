---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CheatCompareTable from '../../components/CheatCompareTable.astro';
import Icon from '../../components/Icon.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import MediaSwiper from '../../components/react/MediaSwiper';
import MotionButton from '../../components/react/MotionButton';
import { cheats, getCheatById, getCheatFeatures } from '../../data/cheats';
import { getProductById } from '../../data/products';
import { breadcrumbSchema, softwareApplicationSchema } from '../../lib/schema';
import { SITE, GET_ACCESS_URL } from '../../lib/site';
import { resolveSocialImage } from '../../lib/social-images';

export function getStaticPaths() {
  return cheats.map((cheat) => ({
    params: { slug: cheat.id },
  }));
}

const { slug } = Astro.params;
const cheat = getCheatById(slug!);

if (!cheat) {
  return Astro.redirect('/cheats/');
}

const cheatFeatures = getCheatFeatures(cheat.id);
const url = `${SITE.url}/cheats/${cheat.id}/`;
const socialImage = resolveSocialImage(`/cheats/${cheat.id}/`);

const relatedProducts = (cheat.relatedProductSlugs ?? [])
  .map((id) => getProductById(id))
  .filter(Boolean);

const schema = [
  softwareApplicationSchema({
    name: `${cheat.name} Arc Raiders Cheat — ${cheat.tier}`,
    description: cheat.seoDescription,
    url,
    image: socialImage.src,
    imageAlt: socialImage.alt,
    category: 'GameApplication',
    featureList: cheatFeatures,
  }),
  breadcrumbSchema([
    { name: 'Home', url: `${SITE.url}/` },
    { name: 'Cheats', url: `${SITE.url}/cheats/` },
    { name: cheat.name, url },
  ]),
];
---

<BaseLayout
  title={cheat.seoTitle}
  description={cheat.seoDescription}
  canonical={url}
  ogType="website"
  ogImage={socialImage.src}
  ogImageAlt={socialImage.alt}
  keywords={cheat.keywords}
  schema={schema}
>
  <section class="section cheat-detail-section">
    <div class="section-inner">
      <div class="cheat-detail-layout">
        <div class="cheat-detail-left">
          <div class="cheat-detail-left-head">
            <h1>{cheat.name} Arc Raiders Cheat</h1>
            <div class="detail-head-badges">
              <span class="cheat-detail-tier">{cheat.tier}</span>
              {cheat.featured && <span class="cheat-card-badge">Popular</span>}
              <span class="listing-meta-pill">Updated {cheat.lastUpdated}</span>
            </div>
          </div>
          <div class="cheat-detail-media">
            <MediaSwiper client:visible media={cheat.media} />
          </div>
          <p class="cheat-detail-desc">{cheat.description}</p>
          {cheat.overview?.map((paragraph) => (
            <p class="cheat-detail-desc">{paragraph}</p>
          ))}
        </div>

        <div class="cheat-detail-features">
          {cheat.setupSteps && cheat.setupSteps.length > 0 && (
            <div class="detail-block">
              <h2 class="cheat-detail-section-title">
                <span class="s-tag">// Setup</span>
                How to Get Started
              </h2>
              <ol class="detail-steps">
                {cheat.setupSteps.map((step) => (
                  <li>{step}</li>
                ))}
              </ol>
            </div>
          )}

          <h2 class="cheat-detail-section-title">
            <span class="s-tag">// Features</span>
            What&apos;s Included
          </h2>
          <ul class="cheat-feature-list">
            {cheatFeatures.map((feature) => (
              <li>
                <Icon name="check" size={15} class="cheat-feature-check" />
                {feature}
              </li>
            ))}
          </ul>
          {cheat.systemRequirements && (
            <div class="cheat-sysreq">
              <h3 class="cheat-sysreq-title">
                <Icon name="settings" size={15} class="cheat-feature-check" />
                System Requirements
              </h3>
              <ul class="cheat-feature-list">
                {cheat.systemRequirements.map((req) => (
                  <li>
                    <Icon name="check" size={15} class="cheat-feature-check" />
                    {req}
                  </li>
                ))}
              </ul>
            </div>
          )}

          {cheat.faqs && cheat.faqs.length > 0 && (
            <div class="detail-block">
              <h2 class="cheat-detail-section-title">Tier FAQ</h2>
              <dl class="detail-faq">
                {cheat.faqs.map((faq) => (
                  <>
                    <dt>{faq.question}</dt>
                    <dd>{faq.answer}</dd>
                  </>
                ))}
              </dl>
            </div>
          )}

          <div class="cheat-detail-actions">
            <MotionButton
              client:visible
              href={GET_ACCESS_URL}
              className="btn-primary cheat-detail-btn"
              hideUrlOnHover={true}
            >
              Get {cheat.name} Access
            </MotionButton>
            <MotionButton client:visible href="/cheats/" className="btn-ghost cheat-detail-btn">
              All Cheats
            </MotionButton>
          </div>

          {relatedProducts.length > 0 && (
            <RelatedLinks
              title="Related products"
              links={relatedProducts.map((product) => ({
                href: `/products/${product!.id}/`,
                label: product!.name,
                description: product!.description,
              }))}
            />
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="section alt-bg">
    <div class="section-inner">
      <div class="cheat-compare-head">
        <div class="s-tag">// Tiers</div>
        <h2 class="cheat-detail-section-title">Compare Arc Raiders Cheat Tiers</h2>
        <p class="cheat-compare-sub">Xray, Pro, and Private — full feature breakdown.</p>
      </div>
      <CheatCompareTable activeId={cheat.id} />
    </div>
  </section>
</BaseLayout>

<style>
  .detail-block {
    margin-bottom: 1.25rem;
  }

  .detail-block--warn {
    padding: 1rem 1.1rem;
    border: 1px solid rgba(234, 179, 8, 0.25);
    border-radius: var(--radius);
    background: rgba(234, 179, 8, 0.06);
  }

  .detail-steps,
  .detail-bullets {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--text2);
    line-height: 1.6;
  }

  .detail-steps li + li,
  .detail-bullets li + li {
    margin-top: 0.45rem;
  }

  .detail-faq {
    margin: 0;
  }

  .detail-faq dt {
    font-weight: 700;
    margin-top: 0.85rem;
  }

  .detail-faq dd {
    margin: 0.35rem 0 0;
    color: var(--text2);
    line-height: 1.55;
  }
</style>
