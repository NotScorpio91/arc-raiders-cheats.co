---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogFeaturedHero from '../../components/BlogFeaturedHero.astro';
import BlogCard from '../../components/BlogCard.astro';
import BlogFilter from '../../components/react/BlogFilter';
import Icon from '../../components/Icon.astro';
import IconLabel from '../../components/IconLabel.astro';
import MotionReveal from '../../components/react/MotionReveal';
import { getCollection } from 'astro:content';
import { collectionPageSchema, breadcrumbSchema } from '../../lib/schema';
import { SITE } from '../../lib/site';
import { resolveSocialImage } from '../../lib/social-images';
import { getFeaturedPost, toBlogCardData } from '../../lib/blog-posts';

const blogSocial = resolveSocialImage('/blog/');

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = getFeaturedPost(posts);
const featuredCard = toBlogCardData(featured);
const gridPosts = posts.filter((p) => p.id !== featured.id).map(toBlogCardData);

const schema = [
  collectionPageSchema({
    title: 'Arc Raiders Blog — ESP, Aimbot & Cheat Guides',
    description: 'Arc Raiders ESP, aimbot, radar, and cheat tier guides — patch-aware tips for Xray, Pro, and Private setups.',
    url: `${SITE.url}/blog/`,
    image: blogSocial.src,
    imageAlt: blogSocial.alt,
  }),
  breadcrumbSchema([
    { name: 'Home', url: `${SITE.url}/` },
    { name: 'Blog', url: `${SITE.url}/blog/` },
  ]),
];
---

<BaseLayout
  title="Arc Raiders Cheats Blog — Guides"
  description="Arc Raiders ESP, aimbot, radar, and cheat guides — 25 patch-aware articles on tiers, settings, extraction intel, and setup."
  canonical={`${SITE.url}/blog/`}
  ogImage={blogSocial.src}
  ogImageAlt={blogSocial.alt}
  schema={schema}
  keywords={['arc raiders blog', 'arc raiders esp guide', 'arc raiders aimbot guide', 'arc raiders cheats']}
>
  <section class="section listing-section blog-index-section">
    <div class="section-inner">
      <MotionReveal client:visible>
        <div class="listing-intro">
          <IconLabel icon="newspaper" label="Blog" />
          <h1>Arc Raiders Cheat Guides</h1>
          <div class="detail-head-badges">
            <span class="listing-meta-pill">
              <Icon name="newspaper" size={11} />
              {posts.length} Articles
            </span>
            <span class="listing-meta-pill">
              <Icon name="eye" size={11} />
              ESP · Aimbot · Setup
            </span>
          </div>
          <p class="listing-intro-desc">
            Deep guides on Arc Raiders ESP, aimbot settings, radar tools, cheat tiers, and extraction
            intel — written for players who want practical raid advantage without fluff.
          </p>
        </div>

        <BlogFeaturedHero post={featuredCard} />

        <div class="blog-index-filter-wrap">
          <BlogFilter client:visible posts={gridPosts} />
        </div>
      </MotionReveal>
    </div>
  </section>
</BaseLayout>
