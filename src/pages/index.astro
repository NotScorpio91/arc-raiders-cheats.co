---
import BaseLayout from '../layouts/BaseLayout.astro';
import CheatTierCard from '../components/CheatTierCard.astro';
import ProductCard from '../components/ProductCard.astro';
import BlogCard from '../components/BlogCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import ShowcaseSlider from '../components/ShowcaseSlider.astro';
import Icon from '../components/Icon.astro';
import IconLabel from '../components/IconLabel.astro';
import MotionReveal from '../components/react/MotionReveal';
import { getCollection } from 'astro:content';
import { cheats, getCheatFeatures } from '../data/cheats';
import { homepageShowcase, homepageHero } from '../data/homepage';
import { homepageGuideIntro, homepageGuideSections, homepageGuideTakeaways } from '../data/homepage-guide';
import { homepageFaqs, products } from '../data/products';
import { GET_ACCESS_URL, SITE } from '../lib/site';
import { resolveSocialImage } from '../lib/social-images';
import {
  websiteSchema,
  faqSchema,
  homepageSoftwareApplicationSchema,
} from '../lib/schema';

const homeSocial = resolveSocialImage('/');

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const schema = [
  homepageSoftwareApplicationSchema(homeSocial.src),
  websiteSchema(),
  faqSchema([...homepageFaqs], homeSocial.src),
];
---

<BaseLayout
  title="Arc Raiders Cheats"
  description="Arc Raiders Cheats with player ESP, loot ESP, aim tools, and 2D radar. Choose Xray, Pro, or Private tiers — updated after major Season 1 patches."
  canonical={`${SITE.url}/`}
  schema={schema}
  keywords={['arc raiders cheats', 'arc raiders esp', 'arc raiders aimbot', 'arc raiders hack']}
>
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-slash hero-slash-left"></div>
    <div class="hero-slash2 hero-slash2-left"></div>
    <div class="hero-slash hero-slash-right"></div>
    <div class="hero-slash2 hero-slash2-right"></div>
    <div class="section-inner hero-inner">
      <div class="hero-content hero-animate">
        <div class="hero-badge">{homepageHero.badge}</div>
        <h1>Arc Raiders Cheats &amp; Tools</h1>
        <p class="hero-desc">{homepageHero.description}</p>
        <div class="hero-btns">
          <button type="button" class="btn-primary" data-go-url={GET_ACCESS_URL}>Browse Cheats</button>
          <a href="/products/" class="btn-ghost">View Products</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--below-fold" id="cheats">
    <div class="section-inner">
      <MotionReveal client:visible>
      <div class="s-head">
        <IconLabel icon="crosshair" label="Cheats" />
        <h2 class="s-title">Choose Your Cheat Tier</h2>
        <p class="s-sub">Buy Xray, Pro, or Private — ESP, aimbot, and extraction tools for every raid.</p>
      </div>
      <div class="aff-grid aff-grid-three cheat-grid animate-grid">
        {cheats.map((cheat) => (
          <CheatTierCard
            icon={cheat.icon}
            name={cheat.name}
            description={cheat.description}
            features={getCheatFeatures(cheat.id)}
            tier={cheat.tier}
            featured={cheat.featured}
            href={`/cheats/${cheat.id}/`}
            ctaLabel={`View ${cheat.name} features`}
          />
        ))}
      </div>
      </MotionReveal>
    </div>
  </section>

  <section class="section section--below-fold showcase-section alt-bg" id="showcase" aria-labelledby="showcase-heading">
    <div class="section-inner">
      <MotionReveal client:visible>
        <div class="s-head showcase-head">
          <IconLabel icon="scan" label="Screenshots" />
          <h2 class="s-title" id="showcase-heading">Arc Raiders Cheat Screenshots</h2>
          <p class="s-sub">
            Real in-game Arc Raiders cheat screenshots — player ESP, loot ESP, bone-targeted aimbot,
            2D radar hack, and overlay menus from our Xray, Pro, and Private tiers.
          </p>
          <ul class="showcase-feature-pills" aria-label="Feature highlights">
            <li><Icon name="eye" size={12} /> Player ESP</li>
            <li><Icon name="loot" size={12} /> Loot ESP</li>
            <li><Icon name="crosshair" size={12} /> Aimbot</li>
            <li><Icon name="radar" size={12} /> 2D Radar</li>
            <li><Icon name="layers" size={12} /> Overlay Menu</li>
          </ul>
        </div>
      </MotionReveal>

      <div class="showcase-panel showcase-panel--single">
        <ShowcaseSlider media={homepageShowcase} />
      </div>
    </div>
  </section>

  <section class="section section--below-fold" id="products">
    <div class="section-inner">
      <MotionReveal client:visible>
      <div class="s-head">
        <IconLabel icon="cloud" label="Products" />
        <h2 class="s-title">Arc Raiders Products &amp; Tools</h2>
        <p class="s-sub">Cloud DMA, UGC, Skin Changer, and HWID Spoofer for a full Arc Raiders cheats stack.</p>
      </div>
      <div class="aff-grid aff-grid-products animate-grid">
        {products.map((product) => (
          <ProductCard {...product} ctaLabel={`Explore ${product.name}`} />
        ))}
      </div>
      </MotionReveal>
    </div>
  </section>

  <section class="section section--below-fold homepage-guide-section alt-bg" id="guide" aria-labelledby="guide-heading">
    <div class="section-inner">
      <MotionReveal client:visible>
      <div class="s-head homepage-guide-head">
        <IconLabel icon="guide" label="Guide" />
        <h2 class="s-title" id="guide-heading">Arc Raiders Cheats Guide</h2>
        <p class="s-sub">
          What to look for when buying Arc Raiders cheats — features, safety, and support without
          the sales pitch.
        </p>
      </div>

      <p class="homepage-guide-intro-text">{homepageGuideIntro}</p>

      <div class="homepage-guide-takeaways" aria-label="Key takeaways">
        <p class="homepage-guide-takeaways-label">Key takeaways</p>
        <ul>
          {homepageGuideTakeaways.map((item) => (
            <li>
              <span class="homepage-guide-takeaway-ico" aria-hidden="true">
                <Icon name={item.icon} size={16} />
              </span>
              <span>{item.text}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="homepage-guide-grid">
        {homepageGuideSections.map((section, index) => (
          <article class="homepage-guide-card" style={`--guide-delay: ${0.04 + index * 0.05}s`}>
            <div class="homepage-guide-card-top">
              <span class="homepage-guide-card-num" aria-hidden="true">
                {String(index + 1).padStart(2, '0')}
              </span>
              <span class="homepage-guide-card-ico" aria-hidden="true">
                <Icon name={section.icon} size={20} />
              </span>
            </div>
            <h3 class="homepage-guide-card-title">{section.title}</h3>
            {section.lead && <p class="homepage-guide-lead">{section.lead}</p>}
            {section.paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
            {section.bullets && section.bullets.length > 0 && (
              <ul class="homepage-guide-bullets">
                {section.bullets.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </div>
      </MotionReveal>
    </div>
  </section>

  <section class="section section--below-fold" id="blog">
    <div class="section-inner">
      <MotionReveal client:visible>
      <div class="s-head">
        <IconLabel icon="newspaper" label="Blog" />
        <h2 class="s-title">Latest Updates</h2>
        <p class="s-sub">Patch breakdowns, meta analysis, and Arc Raiders cheats guides from our team.</p>
      </div>
      <div class="blog-grid blog-grid--homepage animate-grid">
        {blogPosts.map((post, index) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.pubDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
            href={`/blog/${post.id}/`}
            icon={post.data.icon}
            readTime={post.data.readTime}
            coverImage={post.data.coverImage}
            coverImageAlt={post.data.coverImageAlt}
            category={post.data.category}
            index={index}
            ctaLabel={`Read ${post.data.title.split('—')[0].trim()}`}
          />
        ))}
      </div>
      <p class="homepage-blog-cta">
        <a href="/blog/">
          <Icon name="newspaper" size={14} />
          View all guides
          <Icon name="chevron-right" size={14} />
        </a>
      </p>
      </MotionReveal>
    </div>
  </section>

  <section class="section section--below-fold alt-bg" id="faq">
    <div class="section-inner">
      <MotionReveal client:visible>
      <div class="s-head">
        <IconLabel icon="info" label="FAQ" />
        <h2 class="s-title">Quick Answers</h2>
      </div>
      <div class="faq-wrap">
        {homepageFaqs.map((faq) => (
          <FAQAccordion question={faq.question} answer={faq.answer} />
        ))}
      </div>
      <p class="faq-more-link">
        <a href="/faq/"><Icon name="chevron-right" size={14} /> See the full Arc Raiders Cheats FAQ</a>
      </p>
      </MotionReveal>
    </div>
  </section>

  <section class="section section--below-fold">
    <div class="section-inner">
      <MotionReveal client:visible>
      <div class="cta-banner">
        <h2><Icon name="zap" size={22} /> Ready to Run Arc Raiders Cheats?</h2>
        <p>Get Xray, Pro, or Private access — or add Cloud DMA, UGC, Skin Changer, and HWID Spoofer to your setup.</p>
        <button type="button" class="btn-primary" data-go-url={GET_ACCESS_URL}><Icon name="arrow-right" size={16} /> Get Access Now</button>
      </div>
      </MotionReveal>
    </div>
  </section>
</BaseLayout>

<style>
  .faq-more-link {
    margin-top: 1.25rem;
    text-align: center;
    font-size: 0.92rem;
  }

  .faq-more-link a {
    color: var(--accent2);
    text-decoration: none;
    font-weight: 600;
  }

  .faq-more-link a:hover {
    text-decoration: underline;
  }
</style>
