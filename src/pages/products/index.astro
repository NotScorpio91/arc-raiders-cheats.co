---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import MotionReveal from '../../components/react/MotionReveal';
import MotionFAQ from '../../components/react/MotionFAQ';
import { products } from '../../data/products';
import { collectionPageSchema, breadcrumbSchema, itemListSchema, faqSchema } from '../../lib/schema';
import { PRODUCT_PRICING } from '../../lib/pricing';
import { SITE } from '../../lib/site';
import { resolveSocialImage } from '../../lib/social-images';

const productsSocial = resolveSocialImage('/products/');

const productFaqs = [
  {
    question: 'What is Cloud DMA?',
    answer:
      'Cloud DMA is the infrastructure license that provisions a Hyper-V environment on one PC. AWS and GREENWARD are separate purchases required for the supported workflow described at checkout.',
  },
  {
    question: 'What is UGC used for?',
    answer:
      'UGC is a tool builder for account recovery and unban workflows. It helps you configure custom tools, automate appeal steps, and rebuild profiles after account restrictions.',
  },
  {
    question: 'What does Skin Changer do?',
    answer:
      'Skin Changer unlocks weapon skins, character outfits, and rare cosmetics across supported games so you can customize your loadout without buying every marketplace item.',
  },
  {
    question: 'Does HWID Spoofer work with major anti-cheats?',
    answer:
      'Yes. HWID Spoofer masks disk serials, MAC addresses, GPU IDs, and other hardware identifiers. It is built to work with EAC, BattlEye, Vanguard, and other major anti-cheat systems.',
  },
  {
    question: 'How do I get access after purchase?',
    answer:
      'Click Get Access on any cheat or product page — you are taken straight to that product’s checkout for instant delivery. Setup steps and activation details follow immediately after purchase.',
  },
];

const schema = [
  collectionPageSchema({
    title: 'Arc Raiders Cheats Products — Cloud DMA, UGC, Skin Changer & HWID Spoofer',
    description: 'Cloud DMA, UGC, Skin Changer, and HWID Spoofer for Arc Raiders cheats.',
    url: `${SITE.url}/products/`,
    image: productsSocial.src,
    imageAlt: productsSocial.alt,
  }),
  itemListSchema(
    products.map((p) => ({
      name: p.name,
      url: `${SITE.url}/products/${p.id}/`,
      description: p.description,
      pricingPlans: PRODUCT_PRICING[p.id],
    })),
    'Product',
  ),
  breadcrumbSchema([
    { name: 'Home', url: `${SITE.url}/` },
    { name: 'Products', url: `${SITE.url}/products/` },
  ]),
  faqSchema(productFaqs, productsSocial.src),
];
---

<BaseLayout
  title="Arc Raiders Products — DMA, UGC, Spoofer"
  description="Buy Cloud DMA, UGC, Skin Changer, and HWID Spoofer for Arc Raiders. Infrastructure, account tools, cosmetics, and hardware spoofing with instant delivery."
  canonical={`${SITE.url}/products/`}
  ogImage={productsSocial.src}
  ogImageAlt={productsSocial.alt}
  keywords={[
    'arc raiders products',
    'cloud dma',
    'ugc account recovery',
    'skin changer',
    'hwid spoofer',
  ]}
  schema={schema}
>
  <section class="section listing-section">
    <div class="section-inner">
      <MotionReveal client:visible>
        <div class="listing-intro">
          <div class="s-tag">// Products</div>
          <h1>Arc Raiders Cheats Products</h1>
          <div class="detail-head-badges">
            <span class="listing-meta-pill">Cloud DMA · UGC · Skin Changer · HWID Spoofer</span>
          </div>
          <p class="listing-intro-desc">
            Buy Cloud DMA, UGC, Skin Changer, and HWID Spoofer — single-PC infrastructure, account
            recovery tools, cosmetic unlocks, and hardware spoofing for EAC, BattlEye, and Vanguard.
          </p>
        </div>

        <div class="aff-grid aff-grid-products animate-grid">
          {products.map((product) => (
            <ProductCard {...product} ctaLabel={`Explore ${product.name}`} />
          ))}
        </div>
      </MotionReveal>
    </div>
  </section>

  <section class="section alt-bg">
    <div class="section-inner">
      <MotionReveal client:visible>
        <div class="listing-intro listing-intro--compact">
          <div class="s-tag">// FAQ</div>
          <h2 class="listing-subtitle">Product Questions</h2>
          <p class="listing-intro-desc">
            Common questions about Cloud DMA, UGC, Skin Changer, and HWID Spoofer setup and
            compatibility.
          </p>
        </div>
        <MotionFAQ client:visible items={productFaqs} />
      </MotionReveal>
    </div>
  </section>
</BaseLayout>
