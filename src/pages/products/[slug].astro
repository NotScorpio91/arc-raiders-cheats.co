---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import MotionButton from '../../components/react/MotionButton';
import MotionReveal from '../../components/react/MotionReveal';
import { products, getProductById } from '../../data/products';
import { getRelatedCheatsForProduct } from '../../data/cheats';
import { breadcrumbSchema, productSchema } from '../../lib/schema';
import { PRODUCT_PRICING } from '../../lib/pricing';
import { SITE } from '../../lib/site';
import { resolveSocialImage } from '../../lib/social-images';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.id },
  }));
}

const { slug } = Astro.params;
const product = getProductById(slug!);

if (!product) {
  return Astro.redirect('/products/');
}

const url = `${SITE.url}/products/${product.id}/`;
const socialImage = resolveSocialImage(`/products/${product.id}/`);
const accessUrl = product.accessUrl;
const pageDescription = product.seoDescription;
const pageTitle = product.seoTitle;
const fullDescription = product.details
  ? `${product.description} ${product.details}`
  : product.description;

const relatedProducts = (product.relatedSlugs ?? [])
  .map((id) => getProductById(id))
  .filter(Boolean);

const relatedCheats = getRelatedCheatsForProduct(product.id).map((id) => ({
  href: `/cheats/${id}/`,
  label: `${id.charAt(0).toUpperCase()}${id.slice(1)} Arc Raiders Cheat`,
}));

const schema = [
  productSchema({
    name: `${product.name} — Arc Raiders Cheats`,
    description: fullDescription,
    url,
    image: socialImage.src,
    imageAlt: socialImage.alt,
    category: product.tier,
    sku: product.id,
    pricingPlans: PRODUCT_PRICING[product.id],
  }),
  breadcrumbSchema([
    { name: 'Home', url: `${SITE.url}/` },
    { name: 'Products', url: `${SITE.url}/products/` },
    { name: product.name, url },
  ]),
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={url}
  ogType="website"
  ogImage={socialImage.src}
  ogImageAlt={socialImage.alt}
  keywords={product.keywords}
  schema={schema}
>
  <section class="section product-detail-section">
    <div class="section-inner">
      <MotionReveal client:visible>
        <div class="product-detail-layout">
          <div class="product-detail-about">
            <div class="product-detail-about-glow" aria-hidden="true"></div>
            <div class="product-detail-about-icon">
              <Icon name={product.icon} size={36} />
            </div>
            <div class="product-detail-about-head">
              <h1>{product.name} — Arc Raiders Product</h1>
              <div class="detail-head-badges">
                <span class="cheat-detail-tier">{product.tier}</span>
                <span class="listing-meta-pill">Updated {product.lastUpdated}</span>
              </div>
            </div>
            <div class="s-tag">// Overview</div>
            <p class="product-detail-about-desc">{product.description}</p>
            {product.details && <p class="product-detail-about-desc">{product.details}</p>}
            {product.overview?.map((paragraph) => (
              <p class="product-detail-about-desc">{paragraph}</p>
            ))}
            <div class="product-detail-meta">
              <span class="product-detail-meta-pill">{product.features.length} Features</span>
              <span class="product-detail-meta-pill">{product.tier}</span>
            </div>
          </div>

          <div class="product-detail-main">
            {product.setupSteps && product.setupSteps.length > 0 && (
              <div class="detail-block">
                <h2 class="cheat-detail-section-title">
                  <span class="s-tag">// Setup</span>
                  How to Get Started
                </h2>
                <ol class="detail-steps">
                  {product.setupSteps.map((step) => (
                    <li>{step}</li>
                  ))}
                </ol>
              </div>
            )}

            <div class="product-detail-features-head">
              <h2 class="cheat-detail-section-title">
                <span class="s-tag">// Features</span>
                What&apos;s Included
              </h2>
            </div>

            <ul class="product-detail-features">
              {product.features.map((feature) => (
                <li>
                  <Icon name="check" size={15} class="cheat-feature-check" />
                  {feature}
                </li>
              ))}
            </ul>

            {product.faqs && product.faqs.length > 0 && (
              <div class="detail-block">
                <h2 class="cheat-detail-section-title">Product FAQ</h2>
                <dl class="detail-faq">
                  {product.faqs.map((faq) => (
                    <>
                      <dt>{faq.question}</dt>
                      <dd>{faq.answer}</dd>
                    </>
                  ))}
                </dl>
              </div>
            )}

            <div class="product-detail-cta">
              <MotionButton
                client:visible
                href={accessUrl}
                className="btn-primary cheat-detail-btn"
                hideUrlOnHover={true}
              >
                Get {product.name} Access
              </MotionButton>
            </div>

            <RelatedLinks
              title="Related products"
              links={relatedProducts.map((item) => ({
                href: `/products/${item!.id}/`,
                label: item!.name,
                description: item!.description,
              }))}
            />

            {relatedCheats.length > 0 && (
              <RelatedLinks
                title="Related cheat tiers"
                links={relatedCheats}
              />
            )}
          </div>
        </div>
      </MotionReveal>
    </div>
  </section>
</BaseLayout>

<style>
  .detail-block {
    margin-bottom: 1.5rem;
  }

  .detail-block--warn {
    padding: 1rem 1.1rem;
    border: 1px solid rgba(234, 179, 8, 0.25);
    border-radius: var(--radius);
    background: rgba(234, 179, 8, 0.06);
  }

  .detail-steps,
  .detail-bullets {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--text2);
    line-height: 1.6;
  }

  .detail-steps li + li,
  .detail-bullets li + li {
    margin-top: 0.45rem;
  }

  .detail-faq {
    margin: 0;
  }

  .detail-faq dt {
    font-weight: 700;
    margin-top: 0.85rem;
  }

  .detail-faq dd {
    margin: 0.35rem 0 0;
    color: var(--text2);
    line-height: 1.55;
  }
</style>
